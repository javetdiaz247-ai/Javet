local DetectedGuis = {}

local function KillAllFlyGuis()
    for _, g in pairs(DetectedGuis) do
        if g and g.Parent then g:Destroy() end
    end
    DetectedGuis = {}

    for _, v in pairs(LocalPlayer:WaitForChild("PlayerGui"):GetDescendants()) do
        if v:IsA("TextLabel") or v:IsA("TextButton") then
            if v.Text:find("Fly") or v.Text:find("V3") or v.Text:find("UP") or v.Text:find("DOWN") then
                local rootGui = v:FindFirstAncestorOfClass("ScreenGui")
                if rootGui and rootGui.Name ~= "ShothoHub" then
                    rootGui:Destroy()
                end
            end
        end
    end

    local char = LocalPlayer.Character
    if char then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            for _, obj in pairs(hrp:GetChildren()) do
                if obj:IsA("BodyVelocity") or obj:IsA("BodyGyro") then
                    obj:Destroy()
                end
            end
        end
        if char:FindFirstChild("Humanoid") then
            char.Humanoid.PlatformStand = false
        end
    end
end

