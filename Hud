-- DRAG SYSTEM
local dragging = false
local dragStart
local startPosFrame
local startPosMini

local function startDrag(input)
    dragging = true
    dragStart = input.Position
    startPosFrame = frame.Position
    startPosMini = miniBtn.Position
end

local function endDrag(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end

frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        startDrag(input)
    end
end)
frame.InputEnded:Connect(endDrag)

miniBtn.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        startDrag(input)
    end
end)
miniBtn.InputEnded:Connect(endDrag)

UserInputService.InputChanged:Connect(function(input)
    if dragging and (
        input.UserInputType == Enum.UserInputType.MouseMovement
        or input.UserInputType == Enum.UserInputType.Touch
    ) then
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(
            startPosFrame.X.Scale, startPosFrame.X.Offset + delta.X,
            startPosFrame.Y.Scale, startPosFrame.Y.Offset + delta.Y
        )
        miniBtn.Position = UDim2.new(
            startPosMini.X.Scale, startPosMini.X.Offset + delta.X,
            startPosMini.Y.Scale, startPosMini.Y.Offset + delta.Y
        )
    end
end)
